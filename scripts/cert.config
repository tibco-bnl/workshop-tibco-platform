[req]
prompt = no
distinguished_name = dn
req_extensions = ext
input_password = PASSPHRASE
 
[dn]
CN = *.azure.nl.eu.abnamro.com
O = TIBCO
L = Amsterdam
ST = North-Holland
C = NL
 
# This certificate is for wildcard hosts.
[ext]
subjectAltName = \
    DNS:*.cp1-my.azure.nl.eu.abnamro.com,\
    DNS:*.dev1.cp1-my.azure.nl.eu.abnamro.com,\
    DNS:*.dev2.cp1-my.azure.nl.eu.abnamro.com,\
    DNS:*.dev3.cp1-my.azure.nl.eu.abnamro.com,\
    DNS:*.cp1-tunnel.azure.nl.eu.abnamro.com